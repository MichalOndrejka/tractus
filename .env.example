# ---------------------------------------------------------------------------
# Tractus — environment configuration (copy to .env and fill in)
# ---------------------------------------------------------------------------

# GitHub (backlog + code host). A fine-grained PAT with read & write access to
# Contents, Issues, and Pull requests.
GITHUB_TOKEN=
# Comma-separated list of repos the crew may work on, e.g. "octocat/hello,octocat/world"
GITHUB_REPOS=
# Label that marks an issue as picked up by the bot crew
BOT_LABEL=tractus

# Backend
PORT=8787
# SQLite file for operational state (runs/logs/budget/approvals)
DATABASE_PATH=./data/tractus.sqlite

# Anthropic (used later by the agents/worker-manager, not by Phase 0 backend)
ANTHROPIC_API_KEY=

# Budget guardrails
DAILY_BUDGET_USD=10
CONCURRENCY_LIMIT=2
PER_TASK_TOKEN_CAP=200000

# Persistent agent containers
# Base image new agents are created from until they have a trained snapshot.
AGENT_IMAGE=tractus/agent:latest
# Prefix for per-type golden images produced by snapshotting (<prefix><role>:<tag>).
AGENT_IMAGE_PREFIX=tractus/agent-
# How long an agent container may sit idle (ms) before it's stopped to save
# resources. It's started again automatically on the next dispatch.
AGENT_IDLE_STOP_MS=600000
# Auto-save an agent's environment (installed tooling / self-updates) to its own
# image whenever it changes, so the state is durable and inherited by spawned
# copies — no manual snapshot needed. Set to 0 to disable.
AGENT_AUTO_SNAPSHOT=1

# Shared memory (conduit) is configured in the UI (Providers → Memory), which
# stores the MCP URL + bearer key in the local DB. No env vars are required.
