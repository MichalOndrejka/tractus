# ---------------------------------------------------------------------------
# Tractus — environment configuration (copy to .env and fill in)
# ---------------------------------------------------------------------------

# GitHub (backlog + code host). A fine-grained PAT with repo + issues + projects.
GITHUB_TOKEN=
# Comma-separated list of repos the crew may work on, e.g. "octocat/hello,octocat/world"
GITHUB_REPOS=
# Label that marks an issue as picked up by the bot crew
BOT_LABEL=tractus

# Backend
PORT=8787
# SQLite file for operational state (runs/logs/budget/approvals)
DATABASE_PATH=./data/tractus.sqlite

# Anthropic (used later by the agents/worker-manager, not by Phase 0 backend)
ANTHROPIC_API_KEY=

# Budget guardrails
DAILY_BUDGET_USD=10
CONCURRENCY_LIMIT=2
PER_TASK_TOKEN_CAP=200000
